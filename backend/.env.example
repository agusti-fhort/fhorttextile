# Plantilla de variables d'entorn del backend Fhort Textile.
# Copia aquest fitxer a `.env` (NO versionat) i omple els valors reals.
# settings.py les carrega via python-dotenv (load_dotenv(BASE_DIR/.env)).

# Clau secreta de Django. OBLIGATÒRIA. Genera'n una de llarga i aleatòria.
SECRET_KEY=

# Mode debug. En PRODUCCIÓ ha de ser False (mai True: exposa stack traces).
DEBUG=False

# Hosts permesos, separats per comes. settings.py hi afegeix els hosts de
# producció com a fallback. Inclou el wildcard de subdominis de tenant.
ALLOWED_HOSTS=fhorttextile.tech,.fhorttextile.tech,localhost,127.0.0.1

# Base de dades PostgreSQL.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Clau de l'API d'Anthropic (extracció de fitxes tècniques). Opcional en dev.
ANTHROPIC_API_KEY=
